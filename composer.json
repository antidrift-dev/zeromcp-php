{
  "name": "antidrift/zeromcp",
  "description": "Zero-config MCP runtime for PHP",
  "type": "library",
  "license": "MIT",
  "version": "0.1.0",
  "keywords": ["mcp", "zero-config", "tools", "ai-agents"],
  "homepage": "https://github.com/antidrift-dev/zeromcp",
  "authors": [
    {
      "name": "Antidrift",
      "email": "hello@probeo.io"
    }
  ],
  "support": {
    "issues": "https://github.com/antidrift-dev/zeromcp/issues",
    "source": "https://github.com/antidrift-dev/zeromcp/tree/main/php"
  },
  "require": {
    "php": ">=8.1"
  },
  "autoload": {
    "psr-4": {
      "ZeroMcp\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "ZeroMcp\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "bin": ["zeromcp.php"]
}
