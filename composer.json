{
  "name": "antidrift/zeromcp",
  "description": "Zero-config MCP runtime for PHP",
  "type": "library",
  "license": "MIT",
  "version": "0.1.0",
  "require": {
    "php": ">=8.1"
  },
  "autoload": {
    "psr-4": {
      "ZeroMcp\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "ZeroMcp\\Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0"
  },
  "bin": ["zeromcp.php"]
}
